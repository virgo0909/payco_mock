/* =========================================================
   결제내역: 월 계산 헬퍼 (하드코딩 금지 — 전부 DATA.transactions에서 계산)
========================================================= */
const ymOf = d => d.slice(0,7);
function monthsOf(){ return [...new Set(DATA.transactions.map(t=>ymOf(t.date)))].sort().reverse(); }
function monthTotal(m){ return DATA.transactions.filter(t=>ymOf(t.date)===m && t.status==='결제완료').reduce((s,t)=>s+t.amount,0); }
function txnsOfMonth(m){ return DATA.transactions.filter(t=>ymOf(t.date)===m).sort((a,b)=>(a.date+a.time<b.date+b.time?1:-1)); }

let payYm = null;
const WEEKDAY_KO = ['일','월','화','수','목','금','토'];
function fmtDateGroup(dateStr){
  const d = new Date(dateStr + 'T00:00:00');
  return `${d.getMonth()+1}월 ${d.getDate()}일 ${WEEKDAY_KO[d.getDay()]}요일`;
}
function renderPay(){
  const el = screen('pay');
  const months = monthsOf();
  if (!payYm || !months.includes(payYm)) payYm = months[0];
  const total = monthTotal(payYm);
  const txns = txnsOfMonth(payYm);

  const groups = [];
  txns.forEach(t=>{
    let g = groups[groups.length-1];
    if (!g || g.date !== t.date) { g = {date:t.date, items:[]}; groups.push(g); }
    g.items.push(t);
  });

  el.innerHTML = `
    <div class="topbar">
      <button class="topbar-back" onclick="back()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 5l-7 7 7 7"/></svg>
      </button>
      <div class="topbar-title">결제 내역</div>
      <button class="topbar-link" onclick="nav('report')">이용리포트</button>
    </div>
    <div class="scroll">
      <div class="pay-head">
        <label class="pay-month">${Number(payYm.slice(5,7))}월
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          <select onchange="payYm=this.value; renderPay();">
            ${months.map(m=>`<option value="${m}"${m===payYm?' selected':''}>${Number(m.slice(5,7))}월 (${m.slice(0,4)})</option>`).join('')}
          </select>
        </label>
        <div class="pay-total-label">${Number(payYm.slice(5,7))}월 총 결제금액</div>
        <div class="pay-total-amount">${won(total)}</div>
      </div>
      <div class="pay-divider"></div>
      ${groups.length===0 ? `<div class="pay-empty">이용 내역이 없습니다</div>` : groups.map(g=>`
        <div class="pay-date-group">${fmtDateGroup(g.date)}</div>
        ${g.items.map(t=>{
          const cancelled = t.status==='취소완료';
          return `
          <div class="pay-row${cancelled?' cancelled':''}">
            <div class="pay-row-time">${t.time}</div>
            <div class="pay-row-main">
              <div class="pay-row-merchant">${cancelled?`<span class="pay-row-status">취소완료</span>`:''}${t.merchant}</div>
              <div class="pay-row-sub">복지포인트(${t.methodTail})</div>
            </div>
            <div class="pay-row-right">
              <div class="pay-row-amount">${won(t.amount)}</div>
              <div class="pay-row-supply">${won(t.supply)}</div>
            </div>
          </div>`;
        }).join('')}
      `).join('')}
    </div>
  `;
}
/* =========================================================
   이용리포트: 집계 헬퍼 (전부 DATA.transactions에서 계산)
========================================================= */
function sumRange(from,to){ return DATA.transactions.filter(t=>t.status==='결제완료'&&t.date>=from&&t.date<=to).reduce((s,t)=>s+t.amount,0); }
function dayTotal(d){ return DATA.transactions.filter(t=>t.status==='결제완료'&&t.date===d).reduce((s,t)=>s+t.amount,0); }
function addDays(dateStr,n){
  const d = new Date(dateStr+'T00:00:00');
  d.setDate(d.getDate()+n);
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
}
function monthFirstDay(m){ return m+'-01'; }
// 최근 3주(월요일~일요일): 라벨은 각 주의 종료일(일요일) 기준 "N월M주"
function recentWeeks(todayStr, n){
  const today = new Date(todayStr+'T00:00:00');
  const dow = (today.getDay()+6)%7; // 0=월
  const curMon = addDays(todayStr, -dow);
  const out = [];
  for(let i=n-1;i>=0;i--){
    const start = addDays(curMon, -7*i);
    const end = addDays(start, 6);
    const endD = new Date(end+'T00:00:00');
    const label = `${endD.getMonth()+1}월${Math.floor((endD.getDate()-1)/7)+1}주`;
    out.push({label, total: sumRange(start,end)});
  }
  return out;
}
// 최근 N개월(today 기준, monthTotal 재사용)
function recentMonths(todayStr, n){
  const [y,m] = todayStr.slice(0,7).split('-').map(Number);
  const out = [];
  for(let i=n-1;i>=0;i--){
    let yy=y, mm=m-i;
    while(mm<1){ mm+=12; yy--; }
    const ym = `${yy}-${String(mm).padStart(2,'0')}`;
    out.push({label:`${mm}월`, total: monthTotal(ym)});
  }
  return out;
}
function reportBarRow(item, idx, arr, cls){
  const max = Math.max(...arr.map(x=>x.total), 0);
  const pct = max>0 ? Math.max(item.total/max*100, item.total>0?4:0) : 0;
  const isCur = idx===arr.length-1;
  return `
    <div class="rpt-bar-row">
      <div class="rpt-bar-label">${item.label}</div>
      <div class="rpt-bar-track">
        <div class="rpt-bar-fill ${cls}${isCur?' cur':''}" style="width:${pct}%">
          ${pct>=18 ? `<span class="rpt-bar-value">${fmtManwon(item.total)}</span>` : ''}
        </div>
        ${pct<18 ? `<span class="rpt-bar-value outside">${fmtManwon(item.total)}</span>` : ''}
      </div>
    </div>`;
}
function fmtManwon(n){
  if(n===0) return '0원';
  if(n%10000===0) return `${(n/10000).toLocaleString('ko-KR')}만원`;
  return `${(n/10000).toFixed(1)}만원`;
}
let reportYm = null;
function renderReport(){
  const el = screen('report');
  const months = monthsOf();
  const today = DATA.config.today;
  const curYm = ymOf(today);
  if(!reportYm || (!months.includes(reportYm) && reportYm!==curYm)) reportYm = curYm;

  const cum = sumRange(monthFirstDay(reportYm), reportYm===curYm ? today : reportYm+'-31');
  const [ry,rm] = reportYm.split('-').map(Number);
  let py=ry, pm=rm-1; if(pm<1){pm=12;py--;}
  const prevYm = `${py}-${String(pm).padStart(2,'0')}`;
  const prevTotal = monthTotal(prevYm);
  const momDiff = cum - prevTotal;
  const momAbs = Math.abs(momDiff);
  const momWord = momDiff<=0 ? '적게' : '많이';

  const d3 = [addDays(today,-2), addDays(today,-1), today];
  const avg3 = Math.round(d3.reduce((s,d)=>s+dayTotal(d),0)/3);

  const weeks = recentWeeks(today, 3);
  const weekAvg = Math.round(weeks.reduce((s,w)=>s+w.total,0)/weeks.length);
  const weekCls = ['prev2','prev1','cur'];
  const wkDiff = weeks[2].total - weeks[1].total;
  const wkWord = wkDiff<=0 ? '적게' : '많이';

  const monthsCard = recentMonths(today, 3);
  const monAvg = Math.round(monthsCard.reduce((s,m)=>s+m.total,0)/monthsCard.length);
  const monCls = ['prev2','prev1','cur'];
  const monDiff = monthsCard[2].total - monthsCard[1].total;
  const monWord = monDiff<=0 ? '적게' : '많이';

  const hasSpend = cum>0;

  el.innerHTML = `
    <div class="topbar">
      <button class="topbar-back" onclick="back()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 5l-7 7 7 7"/></svg>
      </button>
      <div class="topbar-title">이용리포트</div>
    </div>
    <div class="scroll rpt-scroll">
      <div class="rpt-head">
        <label class="rpt-month">${Number(reportYm.slice(5,7))}월
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          <select onchange="reportYm=this.value; renderReport();">
            ${months.includes(curYm)?'':`<option value="${curYm}"${curYm===reportYm?' selected':''}>${Number(curYm.slice(5,7))}월 (${curYm.slice(0,4)})</option>`}
            ${months.map(m=>`<option value="${m}"${m===reportYm?' selected':''}>${Number(m.slice(5,7))}월 (${m.slice(0,4)})</option>`).join('')}
          </select>
        </label>
        <div class="rpt-range">${Number(reportYm.slice(5,7))}월 1일 부터 ${reportYm===curYm?'오늘':'말일'}까지</div>
        <div class="rpt-cum-row">
          <div class="rpt-cum-amount">${won(cum)}</div>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><path d="M12 8h.01M12 11v5"/></svg>
        </div>
        <div class="rpt-mom">전월대비 <b>${won(momAbs)}</b> ${momWord} 썼어요.</div>
      </div>

      <div class="rpt-section-title">최근 지출
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5l7 7-7 7"/></svg>
      </div>
      ${hasSpend ? '' : `<div class="rpt-empty-card">이번 달에는 아직 지출이 없어요.<br>지난달 지출을 확인해 볼까요? <a href="#" onclick="reportYm='${prevYm}'; renderReport(); return false;">확인하기</a></div>`}

      <div class="rpt-avg-label">최근 3일간 일평균 지출</div>
      <div class="rpt-avg-value">${won(avg3)}</div>

      <div class="rpt-section-title">지난 결제와 비교</div>

      <div class="rpt-card">
        <div class="rpt-card-headline">지난주보다 <b>${won(Math.abs(wkDiff))}</b> ${wkWord} 결제했어요</div>
        ${weeks.map((w,i)=>reportBarRow(w,i,weeks,weekCls[i])).join('')}
        <div class="rpt-avg-badge">3주 평균 : ${won(weekAvg)}</div>
      </div>

      <div class="rpt-card">
        <div class="rpt-card-headline">지난달보다 <b>${won(Math.abs(monDiff))}</b> ${monWord} 결제했어요</div>
        ${monthsCard.map((m,i)=>reportBarRow(m,i,monthsCard,monCls[i])).join('')}
        <div class="rpt-avg-badge">3개월 평균 : ${won(monAvg)}</div>
      </div>
    </div>
  `;
}

/* =========================================================
   부팅
========================================================= */
async function boot(){
  DATA = await fetch('data.json').then(r=>r.json());
  renderHome(); renderMyPayco(); renderWelfare(); renderPay(); renderReport();
  setTimeout(()=>{
    document.getElementById('splash').classList.add('fade');
    nav('home');
  }, 1100);
}
window.addEventListener('DOMContentLoaded', boot);
</script>
</body>
</html>
