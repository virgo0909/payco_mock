<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover" />
<title>PAYCO</title>

<!-- iOS 홈화면(standalone) PWA -->
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />
<meta name="apple-mobile-web-app-title" content="PAYCO" />
<meta name="theme-color" content="#ffffff" />
<link rel="manifest" href="manifest.json" />
<link rel="apple-touch-icon" href="assets/app-icon.png" />

<style>
:root{
  --red:#F13C41; --bg:#ffffff; --surface:#f4f5f7; --surface-2:#eceef1;
  --text:#1a1a1e; --text-2:#8b8f97; --text-3:#b5b9c0; --line:rgba(0,0,0,.06);
  --blue:#2e7cf6; --gold-a:#c8a24a; --gold-b:#a8842f;
  --radius:18px; --ease:cubic-bezier(.34,.7,0,1); --dur:.42s;
  --sat:env(safe-area-inset-top,0px); --sab:env(safe-area-inset-bottom,0px);
}
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{margin:0;height:100%;background:var(--bg);}
body{
  font-family:-apple-system,BlinkMacSystemFont,"SF Pro Text","Apple SD Gothic Neo","Malgun Gothic",system-ui,sans-serif;
  color:var(--text);
  overflow:hidden;
  -webkit-font-smoothing:antialiased;
  text-rendering:optimizeLegibility;
  letter-spacing:-0.01em;
  overscroll-behavior:none;
}
button{font:inherit;color:inherit;border:0;background:none;cursor:pointer;letter-spacing:inherit;}
img{display:block;}

/* ---------- 화면 스택 ---------- */
.screen{
  position:fixed;inset:0;
  background:var(--bg);
  display:flex;flex-direction:column;
  transform:translateX(100%);
  will-change:transform;
  transition:transform var(--dur) var(--ease);
  z-index:2;
  box-shadow:-24px 0 48px rgba(0,0,0,.12);
}
.screen#home{box-shadow:none;}
.screen.active{transform:translateX(0);}
.screen.under{transform:translateX(-18%);}
.screen.under::after{content:"";position:absolute;inset:0;background:#000;opacity:.15;pointer-events:none;transition:opacity var(--dur) var(--ease);}
@media (prefers-reduced-motion:reduce){
  .screen{transition:none;}
}

.scroll{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;overscroll-behavior:contain;}
.pad-top{padding-top:calc(var(--sat) + 8px);}

/* ---------- 스플래시 ---------- */
#splash{
  position:fixed;inset:0;z-index:100;background:var(--bg);
  display:flex;align-items:center;justify-content:center;
  transition:opacity .5s ease;
}
#splash.fade{opacity:0;pointer-events:none;}
.splash-wrap{display:flex;align-items:center;justify-content:center;}
.splash-logo{max-width:60vw;max-height:60px;}
.splash-fallback{
  color:var(--red);font-size:34px;font-weight:800;letter-spacing:.01em;
  font-family:Arial,"SF Pro Text",sans-serif;
}
@media (prefers-reduced-motion:reduce){
  #splash{transition:none;}
}

/* ---------- 씬 전환 로딩 인디케이터 ---------- */
#loadbar{
  position:fixed;top:0;left:0;right:0;height:3px;z-index:200;
  background:var(--red);
  transform:scaleX(0);transform-origin:0 50%;
  opacity:0;
  pointer-events:none;
}
#loadbar.run{
  opacity:1;
  animation:loadbarRun .45s ease-out forwards;
}
@keyframes loadbarRun{
  0%{transform:scaleX(0);opacity:1;}
  100%{transform:scaleX(1);opacity:1;}
}
@media (prefers-reduced-motion:reduce){
  #loadbar.run{animation-duration:.05s;}
}

/* ---------- 홈 ---------- */
.home-header{display:flex;align-items:center;justify-content:space-between;padding:calc(var(--sat) + 14px) 20px 8px;}
.home-title{font-size:26px;font-weight:800;}
.home-icons{display:flex;align-items:center;gap:18px;}
.icon-btn{position:relative;display:flex;align-items:center;justify-content:center;width:26px;height:26px;color:var(--text);}
.icon-btn svg{width:24px;height:24px;}
.icon-badge{position:absolute;top:-7px;right:-9px;min-width:16px;height:16px;padding:0 3px;border-radius:8px;background:var(--red);color:#fff;font-size:10px;font-weight:700;line-height:16px;text-align:center;}

.home-search{margin:6px 20px 14px;padding:12px 16px;border:1.5px solid var(--red);border-radius:24px;display:flex;align-items:center;gap:10px;}
.home-search svg{width:18px;height:18px;flex:none;color:var(--red);}
.home-search span{color:var(--text);font-size:14.5px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}

.home-tabs{display:flex;gap:22px;padding:0 20px 12px;overflow-x:auto;scrollbar-width:none;white-space:nowrap;border-bottom:1px solid var(--line);}
.home-tabs::-webkit-scrollbar{display:none;}
.home-tab{flex:none;padding-bottom:12px;font-size:15px;color:var(--text-2);position:relative;}
.home-tab.active{color:var(--text);font-weight:700;}
.home-tab.active::after{content:"";position:absolute;left:0;right:0;bottom:0;height:2px;background:var(--text);}

.home-banner{margin:16px 20px;padding:20px;border-radius:16px;background:linear-gradient(135deg,#cfe0f5,#e9f1fb);position:relative;overflow:hidden;min-height:120px;}
.home-banner-text{font-size:13.5px;font-weight:700;color:#2255aa;line-height:1.5;}
.home-banner-text b{display:block;font-size:19px;color:#1a3d7c;margin:2px 0 10px;}
.home-banner-cta{display:inline-flex;align-items:center;gap:4px;background:#111;color:#fff;font-size:12.5px;font-weight:600;padding:8px 14px;border-radius:20px;}

.home-section-title{padding:22px 20px 12px;font-size:19px;font-weight:800;}
.home-chips{display:flex;gap:8px;padding:0 20px 16px;overflow-x:auto;scrollbar-width:none;}
.home-chips::-webkit-scrollbar{display:none;}
.chip{flex:none;display:flex;align-items:center;gap:6px;padding:9px 16px;border-radius:20px;background:var(--surface);font-size:14px;font-weight:600;color:var(--text);}
.chip.chip-dark{background:#111;color:#fff;}

.benefit-grid{display:grid;grid-auto-flow:column;grid-template-rows:repeat(2,1fr);gap:20px 14px;padding:4px 20px 24px;overflow-x:auto;scrollbar-width:none;}
.benefit-grid::-webkit-scrollbar{display:none;}
.benefit-item{width:78px;display:flex;flex-direction:column;align-items:center;text-align:center;gap:8px;}
.benefit-logo{width:60px;height:60px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:11px;font-weight:700;line-height:1.2;padding:4px;overflow:hidden;}
.benefit-name{font-size:12.5px;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:78px;}
.benefit-rate{font-size:13px;font-weight:700;color:var(--text);}

/* ---------- MY PAYCO ---------- */
.topbar{display:flex;align-items:center;justify-content:center;position:relative;padding:calc(var(--sat) + 14px) 20px 14px;flex:none;}
.topbar-back{position:absolute;left:12px;top:calc(var(--sat) + 8px);width:36px;height:36px;display:flex;align-items:center;justify-content:center;color:var(--text);}
.topbar-back svg{width:24px;height:24px;}
.topbar-title{font-size:18px;font-weight:700;}

.mp-greet{display:flex;align-items:center;justify-content:space-between;padding:24px 20px 20px;gap:12px;}
.mp-greet-text{font-size:23px;font-weight:800;line-height:1.4;}
.mp-greet-text .gold{color:var(--gold-a);}
.mp-greet-coin{flex:none;font-size:52px;line-height:1;}

.mp-gold-card{margin:0 20px 28px;padding:26px 20px;border-radius:var(--radius);background:linear-gradient(135deg,var(--gold-a),var(--gold-b));display:flex;align-items:center;color:#fff;}
.mp-gold-half{flex:1;text-align:center;font-size:15px;font-weight:700;}
.mp-gold-div{width:1px;height:18px;background:rgba(255,255,255,.5);flex:none;}

.mp-section-title{padding:0 20px 12px;font-size:16px;font-weight:800;}
.mp-welfare{display:flex;align-items:center;gap:10px;margin:0 20px 28px;padding:14px 0;text-align:left;width:calc(100% - 40px);}
.mp-welfare-logo{flex:none;width:28px;height:28px;display:flex;align-items:center;justify-content:center;}
.mp-welfare-name{flex:1;font-size:15px;color:var(--text-2);}
.mp-welfare > svg{width:18px;height:18px;color:var(--text-3);flex:none;}

.mp-point-card{margin:0 20px 16px;padding:20px;border-radius:var(--radius);background:var(--surface);}
.mp-point-row{display:flex;align-items:center;justify-content:space-between;}
.mp-point-label{font-size:14px;font-weight:800;}
.mp-point-label .brand{color:var(--red);}
.mp-point-amount{font-size:26px;font-weight:800;margin-top:6px;}
.mp-charge-btn{padding:9px 16px;border-radius:20px;background:var(--surface-2);font-size:13.5px;font-weight:600;color:var(--text);}
.mp-point-hr{border:0;border-top:1px solid var(--line);margin:16px 0;}
.mp-accrue-row{display:flex;align-items:center;justify-content:space-between;font-size:14.5px;color:var(--text-2);}
.mp-accrue-row .dot{display:inline-flex;align-items:center;justify-content:center;width:14px;height:14px;border-radius:50%;background:var(--surface-2);font-size:10px;margin-left:4px;}
.mp-accrue-val{color:var(--text);font-weight:700;}

.mp-icons-card{margin:0 20px 16px;padding:24px 12px;border-radius:var(--radius);background:var(--surface);display:flex;}
.mp-icon-item{flex:1;display:flex;flex-direction:column;align-items:center;gap:10px;}
.mp-icon-badge{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;color:#fff;}
.mp-icon-count{font-size:17px;font-weight:800;}
.mp-icon-label{font-size:12.5px;color:var(--text-2);}

.mp-coupon-card{margin:0 20px 24px;padding:20px;border-radius:var(--radius);background:var(--surface);}
.mp-coupon-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;}
.mp-coupon-head .mp-section-title{padding:0;}
.mp-coupon-all{font-size:13.5px;color:var(--text-2);display:flex;align-items:center;gap:2px;}
.mp-coupon-all svg{width:14px;height:14px;}
.mp-coupon-empty{width:96px;height:130px;border:1.5px dashed var(--text-3);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:26px;color:var(--text-3);margin:0 auto 20px;}
.mp-together{display:flex;align-items:center;gap:10px;}
.mp-together-emoji{flex:none;width:26px;height:26px;border-radius:50%;background:#c9a6ff;display:flex;align-items:center;justify-content:center;font-size:15px;}
.mp-together-label{flex:1;font-size:14.5px;}
.mp-together-btn{padding:9px 16px;border-radius:20px;background:var(--surface-2);font-size:13.5px;font-weight:600;color:var(--text);}

/* ---------- 기업복지 ---------- */
.topbar-gear{position:absolute;right:12px;top:calc(var(--sat) + 8px);width:36px;height:36px;display:flex;align-items:center;justify-content:center;color:var(--text);}
.topbar-gear svg{width:22px;height:22px;}
.topbar-link{position:absolute;right:16px;top:calc(var(--sat) + 14px);font-size:15px;color:var(--text);}

.wf-profile{display:flex;align-items:flex-start;justify-content:space-between;padding:8px 20px 20px;gap:12px;}
.wf-profile-name{font-size:23px;font-weight:800;margin-bottom:10px;}
.wf-profile-empno{font-size:15px;color:var(--text-2);}
.wf-profile-email{font-size:14px;color:var(--text-2);margin-top:2px;}
.wf-nexon-logo{flex:none;display:flex;align-items:center;gap:5px;font-weight:800;font-size:13px;color:var(--text);line-height:1.1;text-align:right;}
.wf-nexon-logo .sq{width:16px;height:16px;border-radius:3px;background:linear-gradient(135deg,#0a2540 50%,#b7d233 50%);flex:none;}
.wf-nexon-logo-img{height:22px;width:auto;}

.wf-banner{margin:0 20px 20px;padding:16px;border-radius:14px;background:#eaf2fd;font-size:13px;line-height:1.6;color:#1f4fa8;}

.wf-point-card{margin:0 20px 16px;padding:24px 20px;border-radius:var(--radius);background:#c7cf1e;color:#fff;}
.wf-point-title{font-size:18px;font-weight:800;margin-bottom:22px;}
.wf-point-row{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:22px;}
.wf-point-label{font-size:13.5px;color:rgba(255,255,255,.85);}
.wf-point-amount{font-size:24px;font-weight:800;}
.wf-barcode-btn{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:15px;border-radius:12px;background:#fff;color:var(--text);font-size:15px;font-weight:700;}
.wf-barcode-glyph{letter-spacing:1px;font-size:15px;}

.wf-card-row{display:flex;align-items:center;gap:14px;margin:0 20px 16px;padding:16px;border-radius:var(--radius);background:var(--surface);}
.wf-card-thumb{flex:none;width:30px;height:44px;border-radius:4px;background:#e2e4e8;border:1px solid var(--line);object-fit:cover;}
.wf-card-info{flex:1;}
.wf-card-name{font-size:15px;font-weight:700;}
.wf-card-num{font-size:13.5px;color:var(--text-2);margin-top:2px;}
.wf-card-row svg{width:18px;height:18px;color:var(--text-3);flex:none;}

.wf-menu-card{margin:0 20px 24px;padding:24px 8px 8px;border-radius:var(--radius);background:var(--surface);display:flex;flex-wrap:wrap;}
.wf-menu-item{width:25%;display:flex;flex-direction:column;align-items:center;gap:8px;margin-bottom:20px;text-align:center;}
.wf-menu-badge{position:relative;width:48px;height:48px;border-radius:50%;background:var(--surface-2);display:flex;align-items:center;justify-content:center;font-size:22px;}
.wf-menu-badge .dot{position:absolute;top:0;right:0;width:8px;height:8px;border-radius:50%;background:var(--red);}
.wf-menu-label{font-size:12.5px;color:var(--text);}

/* ---------- 결제내역 ---------- */
.pay-head{padding:8px 20px 20px;flex:none;}
.pay-month{display:inline-flex;align-items:center;gap:4px;font-size:15px;color:var(--text);position:relative;}
.pay-month select{position:absolute;inset:0;opacity:0;width:100%;height:100%;cursor:pointer;}
.pay-month svg{width:14px;height:14px;}
.pay-total-label{font-size:15px;color:var(--text);margin-top:14px;}
.pay-total-amount{font-size:30px;font-weight:800;margin-top:6px;}
.pay-divider{height:8px;background:var(--surface);flex:none;}

.pay-date-group{padding:20px 20px 4px;font-size:14.5px;color:var(--text);}
.pay-row{display:flex;align-items:flex-start;gap:12px;padding:14px 20px;}
.pay-row-time{flex:none;width:44px;font-size:13.5px;color:var(--text-2);padding-top:1px;}
.pay-row-main{flex:1;min-width:0;}
.pay-row-merchant{font-size:16px;font-weight:700;color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.pay-row-sub{font-size:13.5px;color:var(--text-2);margin-top:6px;}
.pay-row-right{flex:none;text-align:right;}
.pay-row-amount{font-size:16px;font-weight:700;color:var(--text);}
.pay-row-supply{display:inline-block;font-size:12.5px;color:var(--red);background:rgba(241,60,65,.08);border-radius:4px;padding:2px 6px;margin-top:6px;}
.pay-row.cancelled .pay-row-merchant,.pay-row.cancelled .pay-row-amount{color:var(--text-3);}
.pay-row.cancelled .pay-row-supply{color:var(--text-3);background:var(--surface);}
.pay-row-status{display:inline-block;font-size:12px;font-weight:700;color:var(--text-3);border:1px solid var(--text-3);border-radius:4px;padding:1px 5px;margin-right:6px;}
.pay-empty{padding:60px 20px;text-align:center;color:var(--text-2);font-size:14.5px;}

/* ---------- 이용리포트 ---------- */
.rpt-scroll{background:var(--surface);}
.rpt-head{background:var(--bg);padding:8px 20px 24px;}
.rpt-month{display:inline-flex;align-items:center;gap:4px;font-size:24px;font-weight:800;position:relative;}
.rpt-month select{position:absolute;inset:0;opacity:0;width:100%;height:100%;cursor:pointer;}
.rpt-month svg{width:16px;height:16px;margin-top:4px;}
.rpt-range{font-size:14.5px;color:var(--text-2);margin-top:18px;}
.rpt-cum-row{display:flex;align-items:center;gap:6px;margin-top:6px;}
.rpt-cum-amount{font-size:30px;font-weight:800;}
.rpt-cum-row svg{width:16px;height:16px;color:var(--text-3);}
.rpt-mom{font-size:15px;color:var(--text);margin-top:14px;}
.rpt-mom b{color:var(--blue);font-weight:800;}

.rpt-section-title{display:flex;align-items:center;gap:4px;padding:24px 20px 12px;font-size:18px;font-weight:800;}
.rpt-section-title svg{width:16px;height:16px;color:var(--text-2);}

.rpt-empty-card{margin:0 20px 8px;padding:32px 20px;border-radius:var(--radius);background:var(--surface-2);text-align:center;font-size:14.5px;line-height:1.7;color:var(--text);}
.rpt-empty-card a{color:var(--blue);font-weight:700;}

.rpt-avg-label{padding:24px 20px 8px;font-size:16px;font-weight:800;}
.rpt-avg-value{padding:0 20px 16px;font-size:26px;font-weight:800;}

.rpt-card{margin:0 20px 20px;padding:20px;border-radius:var(--radius);background:var(--bg);}
.rpt-card-headline{font-size:16px;font-weight:700;padding-bottom:16px;border-bottom:1px solid var(--line);margin-bottom:18px;}
.rpt-card-headline b{color:var(--blue);font-weight:800;}

.rpt-bar-row{display:flex;align-items:center;gap:10px;margin-bottom:16px;}
.rpt-bar-row:last-of-type{margin-bottom:0;}
.rpt-bar-label{flex:none;width:52px;font-size:14.5px;color:var(--text);}
.rpt-bar-track{flex:1;position:relative;height:22px;}
.rpt-bar-fill{height:100%;border-radius:4px;background:var(--surface-2);display:flex;align-items:center;justify-content:flex-end;padding:0 8px;min-width:2px;}
.rpt-bar-fill.cur{background:var(--blue);}
.rpt-bar-fill.prev1{background:#bcd6fb;}
.rpt-bar-fill.prev2{background:var(--surface-2);}
.rpt-bar-value{font-size:13px;font-weight:700;color:var(--text);}
.rpt-bar-fill.cur .rpt-bar-value{color:#fff;}
.rpt-bar-value.outside{position:absolute;right:0;top:0;line-height:22px;color:var(--text);}

.rpt-avg-badge{display:block;margin:18px auto 0;padding:8px 16px;border-radius:20px;background:#5b6472;color:#fff;font-size:13px;font-weight:600;text-align:center;width:fit-content;}

.rpt-nodata-card{margin:0 20px 20px;padding:32px 20px;border-radius:var(--radius);background:var(--bg);text-align:center;font-size:14.5px;color:var(--text-2);}

/* ---------- 하단 탭바 ---------- */
.tabbar{display:flex;border-top:1px solid var(--line);background:var(--bg);padding-bottom:var(--sab);flex:none;}
.tab-item{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;padding:9px 0 8px;color:var(--text-3);font-size:11px;position:relative;}
.tab-item svg{width:22px;height:22px;}
.tab-item.active{color:var(--red);}
.tab-item::after{content:"";position:absolute;inset:0;border-radius:12px;background:currentColor;opacity:0;transform:scale(.85);transition:opacity .2s,transform .2s;pointer-events:none;}
.tab-item:active::after{opacity:.08;transform:scale(1);}
@media (prefers-reduced-motion:reduce){
  .tab-item::after{transition:none;}
}
</style>
</head>
<body>

<!-- ===== 스플래시 ===== -->
<section class="screen active" id="splash">
  <div class="splash-wrap"><img src="assets/splash-logo.png" alt="PAYCO" class="splash-logo"
    onerror="this.replaceWith(Object.assign(document.createElement('div'),{className:'splash-fallback',textContent:'PAYCO'}))"></div>
</section>
<div id="loadbar"></div>

<!-- ===== 홈 ===== -->
<section class="screen" id="home"></section>

<!-- ===== MY PAYCO ===== -->
<section class="screen" id="mypayco"></section>

<!-- ===== 기업복지 ===== -->
<section class="screen" id="welfare"></section>

<!-- ===== 결제내역 ===== -->
<section class="screen" id="pay"></section>

<!-- ===== 이용리포트 ===== -->
<section class="screen" id="report"></section>

<script>
/* =========================================================
   상태 & 유틸
========================================================= */
let DATA = null;
const won = n => (n<0?'-':'') + Math.abs(n).toLocaleString('ko-KR') + '원';
const fmtP = n => n.toLocaleString('ko-KR') + ' P';

/* =========================================================
   씬 전환 로딩 인디케이터
========================================================= */
function showLoad(){ const b=document.getElementById('loadbar'); b.className='run'; }
function hideLoad(){ document.getElementById('loadbar').className=''; }

/* =========================================================
   화면 전환(스택)
========================================================= */
const stack=[];
function screen(id){ return document.getElementById(id); }
function nav(id){
  showLoad();
  setTimeout(()=>{
    const cur=stack[stack.length-1];
    if (cur) { screen(cur).classList.remove('active'); screen(cur).classList.add('under'); }
    screen(id).classList.remove('under'); screen(id).classList.add('active');
    stack.push(id);
    hideLoad();
  }, 420);
}
function back(){
  if (stack.length<=1) return;
  showLoad();
  setTimeout(()=>{
    const cur=stack.pop();
    const prev=stack[stack.length-1];
    screen(cur).classList.remove('active');
    screen(prev).classList.remove('under'); screen(prev).classList.add('active');
    hideLoad();
  }, 420);
}

